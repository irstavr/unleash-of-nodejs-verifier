{
  "name": "unleash-openfeature-nodejs-verifier",
  "version": "0.1.0",
  "description": "Verification of Node.js Unleash OpenFeature provider",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./contract.json": "./contract.json",
    "./fixtures/unleash-features.json": "./fixtures/unleash-features.json",
    "./fixtures/frontend-toggles.json": "./fixtures/frontend-toggles.json"
  },
  "files": ["dist", "contract.json", "fixtures"],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "demo": "tsx examples/demo/index.ts",
    "contract:export": "tsx scripts/export-contract.ts",
    "verify:web": "vitest run test/web-scenarios.test.ts",
    "verify:server": "vitest run test/scenarios.test.ts test/variant-stick.test.ts",
    "verify:version": "bash scripts/verify-version.sh",
    "verify:matrix": "bash scripts/verify-matrix.sh"
  },
  "dependencies": {
    "@openfeature/server-sdk": "^1.18.0",
    "@openfeature/web-sdk": "^1.9.0",
    "@openfeature/unleash-web-provider": "^0.1.1",
    "@unleash/openfeature-node-provider": "file:../unleash-js-openfeature-provider",
    "unleash-client": "^6.11.0",
    "unleash-proxy-client": "^3.8.0"
  },
  "overrides": {
    "unleash-client": "$unleash-client",
    "@openfeature/server-sdk": "$@openfeature/server-sdk"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}